// prisma/schema.prisma
// Requires XD_POSTGRES (Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("XD_POSTGRES")
}

enum BrandStatus {
  SETUP_PENDING
  ACTIVE
  DISABLED
}

enum BrandEnvironment {
  PRODUCTION
  PREVIEW
}

enum BrandHostKind {
  PUBLIC
  ADMIN
  APEX
  ALIAS
}

enum BrandEmailConfigStatus {
  ACTIVE
  INACTIVE
}

enum BrandEmailProvider {
  RESEND
}

enum BrandConsentNoticeStatus {
  DRAFT
  PUBLISHED
}

enum BackofficeRole {
  SUPERADMIN
  STAFF
}

enum BackofficeUserStatus {
  ACTIVE
  BLOCKED
}

enum BackofficeMfaMethod {
  AUTHENTICATOR_APP
}

enum ExternalUserStatus {
  ACTIVE
  BLOCKED
}

enum PartnerKind {
  PARTICIPANT
  SPONSOR
}

enum PartnerUserStatus {
  ACTIVE
  BLOCKED
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(ACTIVE)
  role          UserRole   @default(USER)
  createdAt     DateTime   @default(now())
  lastLoginAt   DateTime?

  accounts    Account[]
  sessions    Session[]
  loginEvents LoginEvent[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@index([identifier])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset flow (store HASHED token, not raw)
model PasswordResetToken {
  identifier String // user email (lowercased)
  token      String   @unique // SHA-256 hash of the raw token
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model LoginEvent {
  id          String   @id @default(cuid())
  userId      String
  ip          String
  countryIso2 String?
  countryName String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum PromptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ScheduleEventSeriesStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ScheduleRecurrencePattern {
  NONE
  WEEKLY
}

enum ScheduleWeekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum ScheduleEventOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum ScheduleResourceType {
  STAGE
  FOOD_SPOT
  MARKET_SPOT
  OTHER
}

enum ScheduleParticipantType {
  ENTERTAINMENT
  FOOD_VENDOR
  MARKET_VENDOR
}

enum ScheduleParticipantSource {
  MANUAL
  PARTNER_APPROVED
}

enum ScheduleParticipantStatus {
  ACTIVE
  INACTIVE
}

enum PartnerEntertainmentType {
  LIVE_BAND
  DJ
  COMEDY
  MAGIC
}

enum PartnerFoodSetupType {
  TRUCK
  TRAILER
  CART
  STAND
}

enum PartnerMarketType {
  APPAREL
  JEWELRY
  DECOR
  SKINCARE
  FOOD
  SERVICE
  OTHER
}

enum PartnerSponsorType {
  DIRECT
  IN_KIND
  MEDIA
}

enum PartnerAssetKind {
  PROFILE_IMAGE
  DOCUMENT
}

enum PartnerAssetStorageProvider {
  CF_R2
}

enum PartnerAssetStorageBucket {
  PUBLIC_MEDIA
  PRIVATE_DOCUMENTS
}

enum PartnerApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum PartnerApplicationReviewDecision {
  NOTE
  MARK_IN_REVIEW
  APPROVE
  REJECT
}

enum ParticipantRequirementType {
  BUSINESS_LICENSE
  HEALTH_PERMIT
  BUSINESS_INSURANCE
  FIRE_PERMIT
}

enum ParticipantRequirementReviewerState {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum ScheduleAssignmentKind {
  TIMED_SLOT
  FULL_DAY
}

enum ScheduleAssignmentStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum SchedulePublicFeedOrderBy {
  TIME_ASC
  TIME_DESC
  LOCATION_ID
  NAME_ASC
  NAME_DESC
}

enum SchedulePublicFeedResourceSelectionMode {
  ALL
  SELECTED
}

model Brand {
  id        String      @id @default(cuid())
  brandKey  String      @unique
  name      String
  status    BrandStatus @default(SETUP_PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  hosts                           BrandHost[]
  emailConfig                     BrandEmailConfig?
  consentNotices                  BrandConsentNotice[]
  categories                      Category[]
  prompts                         Prompt[]
  articleCategories               ArticleCategory[]
  articles                        Article[]
  leads                           Lead[]
  leadEvents                      LeadEvent[]
  scheduleEventSerieses           ScheduleEventSeries[]
  scheduleEventOccurrences        ScheduleEventOccurrence[]
  scheduleResources               ScheduleResource[]
  scheduleParticipants            ScheduleParticipant[]
  scheduleAssignments             ScheduleAssignment[]
  schedulePublicFeeds             SchedulePublicFeed[]
  staffAccesses                   BackofficeUserBrandAccess[]
  externalUsers                   ExternalUser[]
  externalAccounts                ExternalAccount[]
  externalLoginEvents             ExternalLoginEvent[]
  externalVerificationTokens      ExternalVerificationToken[]
  externalEmailVerificationTokens ExternalEmailVerificationToken[]
  externalPasswordResetTokens     ExternalPasswordResetToken[]
  partnerUsers                    PartnerUser[]
  partnerProfiles                 PartnerProfile[]
  partnerAssets                   PartnerAsset[]
  partnerApplications             PartnerApplication[]
  participantRequirements         ParticipantRequirement[]
  sponsorTiers                    SponsorTier[]
  sponsorEventAssignments         SponsorEventAssignment[]
  partnerLoginEvents              PartnerLoginEvent[]
  partnerEmailVerificationTokens  PartnerEmailVerificationToken[]
  partnerPasswordResetTokens      PartnerPasswordResetToken[]
  websiteSessions                 WebsiteSession[]
  websiteAnalyticsEvents          WebsiteAnalyticsEvent[]
}

model BrandHost {
  id          String           @id @default(cuid())
  brandId     String
  host        String           @unique
  environment BrandEnvironment
  kind        BrandHostKind    @default(PUBLIC)
  isCanonical Boolean          @default(false)
  createdAt   DateTime         @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([environment, kind])
}

model BrandEmailConfig {
  id                String                 @id @default(cuid())
  brandId           String                 @unique
  status            BrandEmailConfigStatus @default(INACTIVE)
  provider          BrandEmailProvider     @default(RESEND)
  fromName          String?
  fromEmail         String?
  replyToEmail      String?
  supportEmail      String?
  providerSecretRef String?
  settings          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model BrandConsentNotice {
  id           String                   @id @default(cuid())
  brandId      String
  version      Int
  status       BrandConsentNoticeStatus
  title        String
  message      String
  acceptLabel  String
  declineLabel String
  publishedAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, version])
  @@index([brandId, status])
  @@index([brandId, publishedAt])
}

model ScheduleEventSeries {
  id                           String                    @id @default(cuid())
  brandId                      String
  name                         String
  slug                         String
  color                        String                    @default("#ef4444")
  description                  String?
  timezone                     String
  status                       ScheduleEventSeriesStatus @default(DRAFT)
  recurrencePattern            ScheduleRecurrencePattern @default(NONE)
  recurrenceInterval           Int                       @default(1)
  recurrenceDays               ScheduleWeekday[]         @default([])
  seasonStartsOn               DateTime
  seasonEndsOn                 DateTime
  occurrenceDayStartsAtMinutes Int                       @default(0)
  occurrenceDayEndsAtMinutes   Int                       @default(1440)
  metadata                     Json?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt

  brand                   Brand                     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  occurrences             ScheduleEventOccurrence[]
  resources               ScheduleResource[]
  feeds                   SchedulePublicFeed[]
  partnerApplications     PartnerApplication[]
  sponsorEventAssignments SponsorEventAssignment[]

  @@unique([brandId, slug])
  @@index([brandId])
  @@index([status])
  @@index([seasonStartsOn, seasonEndsOn])
}

model ScheduleEventOccurrence {
  id                    String                        @id @default(cuid())
  brandId               String
  scheduleEventSeriesId String
  name                  String?
  occursOn              DateTime
  dayStartsAtMinutes    Int
  dayEndsAtMinutes      Int
  status                ScheduleEventOccurrenceStatus @default(SCHEDULED)
  metadata              Json?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  brand       Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  series      ScheduleEventSeries  @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: Cascade)
  assignments ScheduleAssignment[]

  @@unique([scheduleEventSeriesId, occursOn])
  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([occursOn])
  @@index([brandId, occursOn])
}

model ScheduleResource {
  id                    String               @id @default(cuid())
  brandId               String
  scheduleEventSeriesId String?
  name                  String
  slug                  String
  locationId            String
  type                  ScheduleResourceType
  description           String?
  sortOrder             Int                  @default(0)
  isActive              Boolean              @default(true)
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  brand          Brand                        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  series         ScheduleEventSeries?         @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: SetNull)
  assignments    ScheduleAssignment[]
  feedSelections SchedulePublicFeedResource[]

  @@unique([brandId, slug])
  @@unique([brandId, name])
  @@unique([scheduleEventSeriesId, locationId])
  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([type, isActive])
}

model ScheduleParticipant {
  id               String                    @id @default(cuid())
  brandId          String
  partnerProfileId String?                   @unique
  displayName      String
  slug             String
  type             ScheduleParticipantType
  source           ScheduleParticipantSource @default(MANUAL)
  status           ScheduleParticipantStatus @default(ACTIVE)
  summary          String?
  metadata         Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  brand          Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  partnerProfile PartnerProfile?      @relation("ScheduleParticipantPartnerProfile", fields: [partnerProfileId], references: [id], onDelete: SetNull)
  assignments    ScheduleAssignment[]

  @@unique([brandId, slug])
  @@index([brandId])
  @@index([type, status])
  @@index([source])
  @@index([displayName])
}

model ScheduleAssignment {
  id                        String                   @id @default(cuid())
  brandId                   String
  scheduleEventOccurrenceId String
  scheduleResourceId        String
  scheduleParticipantId     String
  kind                      ScheduleAssignmentKind
  status                    ScheduleAssignmentStatus @default(DRAFT)
  startsAtMinutes           Int
  endsAtMinutes             Int
  publicTitle               String?
  publicSubtitle            String?
  publicDescription         String?
  publicLocationLabel       String?
  publicUrl                 String?
  internalNotes             String?
  metadata                  Json?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  brand       Brand                   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  occurrence  ScheduleEventOccurrence @relation(fields: [scheduleEventOccurrenceId], references: [id], onDelete: Cascade)
  resource    ScheduleResource        @relation(fields: [scheduleResourceId], references: [id], onDelete: Cascade)
  participant ScheduleParticipant     @relation(fields: [scheduleParticipantId], references: [id], onDelete: Cascade)

  @@unique([scheduleEventOccurrenceId, scheduleResourceId, scheduleParticipantId, startsAtMinutes, endsAtMinutes])
  @@index([brandId])
  @@index([scheduleEventOccurrenceId])
  @@index([brandId, scheduleEventOccurrenceId])
  @@index([scheduleResourceId])
  @@index([scheduleParticipantId])
  @@index([status])
}

model SchedulePublicFeed {
  id                    String                                  @id @default(cuid())
  brandId               String
  scheduleEventSeriesId String
  feedId                String                                  @unique @default(cuid())
  startsOn              DateTime
  endsOn                DateTime
  weekdays              ScheduleWeekday[]                       @default([])
  resourceType          ScheduleResourceType
  resourceSelectionMode SchedulePublicFeedResourceSelectionMode @default(SELECTED)
  participantType       ScheduleParticipantType
  orderBy               SchedulePublicFeedOrderBy               @default(TIME_ASC)
  isActive              Boolean                                 @default(true)
  metadata              Json?
  createdAt             DateTime                                @default(now())
  updatedAt             DateTime                                @updatedAt

  brand     Brand                        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  series    ScheduleEventSeries          @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: Cascade)
  resources SchedulePublicFeedResource[]

  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([isActive])
}

model SchedulePublicFeedResource {
  id                   String   @id @default(cuid())
  schedulePublicFeedId String
  scheduleResourceId   String
  createdAt            DateTime @default(now())

  feed     SchedulePublicFeed @relation(fields: [schedulePublicFeedId], references: [id], onDelete: Cascade)
  resource ScheduleResource   @relation(fields: [scheduleResourceId], references: [id], onDelete: Restrict)

  @@unique([schedulePublicFeedId, scheduleResourceId])
  @@index([schedulePublicFeedId])
  @@index([scheduleResourceId])
}

model InstallProfile {
  id               String    @id @default("install")
  displayName      String?
  setupCompletedAt DateTime?
  primaryBrandId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([primaryBrandId])
}

model BackofficeUser {
  id                          String               @id @default(cuid())
  username                    String               @unique
  email                       String?              @unique
  passwordHash                String
  role                        BackofficeRole       @default(STAFF)
  status                      BackofficeUserStatus @default(ACTIVE)
  mfaMethod                   BackofficeMfaMethod?
  mfaEnabledAt                DateTime?
  mfaSecretEncrypted          String?
  mfaRecoveryCodesEncrypted   String?
  mfaRecoveryCodesGeneratedAt DateTime?
  lastSelectedBrandKey        String?
  uiPreferences               Json?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  lastLoginAt                 DateTime?

  brandAccesses                   BackofficeUserBrandAccess[]
  accounts                        BackofficeAccount[]
  sessions                        BackofficeSession[]
  loginEvents                     BackofficeLoginEvent[]
  partnerApplicationReviews       PartnerApplicationReview[]  @relation("PartnerApplicationReviewReviewer")
  reviewedParticipantRequirements ParticipantRequirement[]    @relation("ParticipantRequirementReviewer")

  @@index([email])
}

model BackofficeLoginEvent {
  id               String   @id @default(cuid())
  backofficeUserId String
  ip               String
  countryIso2      String?
  countryName      String?
  userAgent        String?
  createdAt        DateTime @default(now())

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@index([backofficeUserId])
  @@index([createdAt])
}

model BackofficeUserBrandAccess {
  userId    String
  brandId   String
  createdAt DateTime @default(now())

  user  BackofficeUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([userId, brandId])
  @@index([brandId])
}

model BackofficeAccount {
  id                String  @id @default(cuid())
  backofficeUserId  String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([backofficeUserId])
}

model BackofficeSession {
  id               String   @id @default(cuid())
  sessionToken     String   @unique
  backofficeUserId String
  expires          DateTime

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@index([backofficeUserId])
}

model BackofficeVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

model BackofficePasswordResetToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model ExternalUser {
  id            String             @id @default(cuid())
  brandId       String
  email         String?
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  status        ExternalUserStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lastLoginAt   DateTime?

  brand       Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  accounts    ExternalAccount[]
  sessions    ExternalSession[]
  loginEvents ExternalLoginEvent[]

  @@unique([brandId, email])
  @@index([brandId])
  @@index([email])
}

model ExternalAccount {
  id                String  @id @default(cuid())
  externalUserId    String
  brandId           String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user  ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  brand Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, provider, providerAccountId])
  @@index([externalUserId])
  @@index([brandId])
}

model ExternalSession {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  externalUserId String
  expires        DateTime

  user ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)

  @@index([externalUserId])
}

model ExternalLoginEvent {
  id             String   @id @default(cuid())
  externalUserId String
  brandId        String
  ip             String
  countryIso2    String?
  countryName    String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user  ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  brand Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([externalUserId])
  @@index([brandId])
  @@index([createdAt])
}

model ExternalVerificationToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, identifier, token])
  @@index([brandId, identifier])
}

model ExternalEmailVerificationToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model ExternalPasswordResetToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model PartnerUser {
  id                       String            @id @default(cuid())
  brandId                  String
  email                    String
  passwordHash             String
  kind                     PartnerKind
  status                   PartnerUserStatus @default(ACTIVE)
  emailVerified            DateTime?
  passwordChangeRequiredAt DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  lastLoginAt              DateTime?

  brand       Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  profile     PartnerProfile?
  sessions    PartnerSession[]
  loginEvents PartnerLoginEvent[]

  @@unique([brandId, email])
  @@index([brandId])
  @@index([email])
  @@index([kind, status])
}

model PartnerSession {
  id            String   @id @default(cuid())
  sessionToken  String   @unique
  partnerUserId String
  expires       DateTime

  user PartnerUser @relation(fields: [partnerUserId], references: [id], onDelete: Cascade)

  @@index([partnerUserId])
}

model PartnerLoginEvent {
  id            String   @id @default(cuid())
  partnerUserId String
  brandId       String
  ip            String
  countryIso2   String?
  countryName   String?
  userAgent     String?
  createdAt     DateTime @default(now())

  user  PartnerUser @relation(fields: [partnerUserId], references: [id], onDelete: Cascade)
  brand Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([partnerUserId])
  @@index([brandId])
  @@index([createdAt])
}

model PartnerEmailVerificationToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model PartnerPasswordResetToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model PartnerProfile {
  id                 String    @id @default(cuid())
  brandId            String
  partnerUserId      String    @unique
  slug               String
  contactName        String
  contactPhone       String
  displayName        String
  summary            String?
  description        String?
  profileCompletedAt DateTime?
  mainImageAssetId   String?   @unique
  mainWebsiteUrl     String?
  socialLinks        Json?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  brand               Brand                      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user                PartnerUser                @relation(fields: [partnerUserId], references: [id], onDelete: Cascade)
  mainImageAsset      PartnerAsset?              @relation("PartnerMainImage", fields: [mainImageAssetId], references: [id], onDelete: SetNull)
  assets              PartnerAsset[]             @relation("PartnerProfileAssets")
  applications        PartnerApplication[]
  participantProfile  ParticipantPartnerProfile?
  sponsorProfile      SponsorPartnerProfile?
  scheduleParticipant ScheduleParticipant?       @relation("ScheduleParticipantPartnerProfile")

  @@unique([brandId, slug])
  @@index([brandId])
  @@index([displayName])
}

model ParticipantPartnerProfile {
  partnerProfileId    String                    @id
  participantType     ScheduleParticipantType
  entertainmentType   PartnerEntertainmentType?
  entertainmentStyle  String?
  foodStyle           String?
  foodSetupType       PartnerFoodSetupType?
  marketType          PartnerMarketType?
  specialRequirements String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  profile      PartnerProfile           @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  requirements ParticipantRequirement[]

  @@index([participantType])
}

model SponsorPartnerProfile {
  partnerProfileId   String              @id
  productServiceType String
  audienceProfile    String?
  marketingGoals     String?
  onsitePlacement    String?
  signageInformation String?
  staffed            Boolean?
  sponsorType        PartnerSponsorType?
  requests           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  profile          PartnerProfile           @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  eventAssignments SponsorEventAssignment[]
}

model PartnerAsset {
  id               String                      @id @default(cuid())
  brandId          String
  partnerProfileId String
  kind             PartnerAssetKind
  storageProvider  PartnerAssetStorageProvider @default(CF_R2)
  storageBucket    PartnerAssetStorageBucket
  objectKey        String
  fileName         String
  mimeType         String
  sizeBytes        Int
  checksumSha256   String?
  imageWidth       Int?
  imageHeight      Int?
  metadata         Json?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  brand                   Brand                    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  profile                 PartnerProfile           @relation("PartnerProfileAssets", fields: [partnerProfileId], references: [id], onDelete: Cascade)
  usedAsMainImageBy       PartnerProfile?          @relation("PartnerMainImage")
  participantRequirements ParticipantRequirement[] @relation("ParticipantRequirementAsset")

  @@unique([storageBucket, objectKey])
  @@index([brandId])
  @@index([partnerProfileId])
  @@index([kind])
  @@index([storageBucket])
}

model PartnerApplication {
  id                       String                   @id @default(cuid())
  brandId                  String
  partnerProfileId         String
  scheduleEventSeriesId    String
  applicationKind          PartnerKind
  submittedProfileSnapshot Json?
  status                   PartnerApplicationStatus @default(DRAFT)
  submittedAt              DateTime?
  approvedAt               DateTime?
  rejectedAt               DateTime?
  withdrawnAt              DateTime?
  metadata                 Json?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  brand       Brand                      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  profile     PartnerProfile             @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  eventSeries ScheduleEventSeries        @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: Cascade)
  reviews     PartnerApplicationReview[]

  @@unique([partnerProfileId, scheduleEventSeriesId])
  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([status])
  @@index([applicationKind, status])
}

model PartnerApplicationReview {
  id                   String                           @id @default(cuid())
  partnerApplicationId String
  reviewerUserId       String?
  decision             PartnerApplicationReviewDecision
  notes                String?
  metadata             Json?
  createdAt            DateTime                         @default(now())

  application PartnerApplication @relation(fields: [partnerApplicationId], references: [id], onDelete: Cascade)
  reviewer    BackofficeUser?    @relation("PartnerApplicationReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([partnerApplicationId])
  @@index([reviewerUserId])
  @@index([decision])
  @@index([createdAt])
}

model ParticipantRequirement {
  id                   String                              @id @default(cuid())
  brandId              String
  partnerProfileId     String
  requirementType      ParticipantRequirementType
  partnerAssetId       String?                             @unique
  expiresAt            DateTime?
  reviewerState        ParticipantRequirementReviewerState @default(PENDING_REVIEW)
  reviewerNotes        String?
  lastReviewedAt       DateTime?
  lastReviewedByUserId String?
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt

  brand          Brand                     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  profile        ParticipantPartnerProfile @relation(fields: [partnerProfileId], references: [partnerProfileId], onDelete: Cascade)
  asset          PartnerAsset?             @relation("ParticipantRequirementAsset", fields: [partnerAssetId], references: [id], onDelete: SetNull)
  lastReviewedBy BackofficeUser?           @relation("ParticipantRequirementReviewer", fields: [lastReviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([partnerProfileId, requirementType])
  @@index([brandId])
  @@index([reviewerState])
  @@index([expiresAt])
  @@index([lastReviewedByUserId])
}

model SponsorTier {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand            Brand                    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  eventAssignments SponsorEventAssignment[]

  @@unique([brandId, name])
  @@index([brandId])
  @@index([brandId, isActive, sortOrder])
}

model SponsorEventAssignment {
  id                      String   @id @default(cuid())
  brandId                 String
  sponsorPartnerProfileId String
  scheduleEventSeriesId   String
  sponsorTierId           String?
  notes                   String?
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  brand          Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  sponsorProfile SponsorPartnerProfile @relation(fields: [sponsorPartnerProfileId], references: [partnerProfileId], onDelete: Cascade)
  eventSeries    ScheduleEventSeries   @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: Cascade)
  tier           SponsorTier?          @relation(fields: [sponsorTierId], references: [id], onDelete: SetNull)

  @@unique([sponsorPartnerProfileId, scheduleEventSeriesId])
  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([sponsorTierId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  brandId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  brand   Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  prompts Prompt[]

  @@unique([brandId, name])
  @@unique([brandId, slug])
  @@index([brandId])
}

model Prompt {
  id          String       @id @default(cuid())
  title       String
  description String?
  content     String
  status      PromptStatus @default(DRAFT)

  // Ordering + tags
  sortOrder Int      @default(0)
  tags      String[] @default([])

  brandId    String?
  categoryId String?
  brand      Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([categoryId])
  @@index([title])
}

// --- Articles (separate from Prompt Library) ---

model ArticleCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String
  brandId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  articles Article[]

  @@unique([brandId, name])
  @@unique([brandId, slug])
  @@index([brandId])
}

model Article {
  id      String       @id @default(cuid())
  title   String
  slug    String
  summary String
  content String
  status  PromptStatus @default(DRAFT)

  brandId    String?
  categoryId String?
  brand      Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category   ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Optional tags (Postgres text[])
  tags String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, slug])
  @@index([brandId])
  @@index([status])
  @@index([categoryId])
  @@index([title])
}

// --- Leads (durable lead records for cross-referencing / analytics) ---

enum LeadSource {
  CONTACT
  CHAT
}

enum WebsiteAnalyticsSourceCategory {
  DIRECT
  SEARCH
  SOCIAL
  REFERRAL
  EMAIL
  PAID
  AI_REFERRAL
  UNKNOWN
}

enum WebsiteAnalyticsSourceMedium {
  DIRECT
  ORGANIC
  SOCIAL
  REFERRAL
  EMAIL
  PAID
  AI_REFERRAL
  UNKNOWN
}

enum WebsiteAnalyticsEventType {
  SESSION_START
  PAGE_VIEW
  ENGAGEMENT_PING
  SESSION_END
  CONVERSION
  WEB_VITAL
  PERFORMANCE_METRIC
}

enum WebsiteAnalyticsConversionType {
  CONTACT_SUBMIT
  CHAT_LEAD_SUBMIT
  CLIENT_LOGIN_SUCCESS
  CLIENT_SIGNUP_CREATED
  CLIENT_SIGNUP_VERIFIED
}

model Lead {
  id        String     @id @default(cuid())
  brandId   String?
  source    LeadSource
  name      String?
  email     String?
  ip        String?
  raw       Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  brand  Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)
  events LeadEvent[]

  @@index([brandId])
  @@index([source])
  @@index([createdAt])
  @@index([email])
}

// --- Lead events (append-only timeline; source of truth for Leads + Analytics) ---

model LeadEvent {
  id             String     @id @default(cuid())
  brandId        String?
  source         LeadSource
  // Optional: link to a durable Lead summary row when available (CONTACT always, CHAT optionally)
  leadId         String?
  conversationId String?
  ip             String?
  countryIso2    String?
  countryName    String?
  userAgent      String?
  referer        String?
  raw            Json?
  createdAt      DateTime   @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  lead  Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([source])
  @@index([createdAt])
  @@index([leadId])
  @@index([conversationId])
}

model WebsiteSession {
  id              String                         @id @default(cuid())
  brandId         String
  sessionId       String
  startedAt       DateTime
  lastSeenAt      DateTime
  endedAt         DateTime?
  landingUrl      String?
  landingPath     String?
  lastPath        String?
  pageViewCount   Int                            @default(0)
  engagedSeconds  Int                            @default(0)
  engaged         Boolean                        @default(false)
  bounced         Boolean                        @default(false)
  converted       Boolean                        @default(false)
  conversionCount Int                            @default(0)
  sourceCategory  WebsiteAnalyticsSourceCategory @default(UNKNOWN)
  sourcePlatform  String?
  sourceMedium    WebsiteAnalyticsSourceMedium   @default(UNKNOWN)
  referrerHost    String?
  referer         String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  fbclid          String?
  msclkid         String?
  ttclid          String?
  countryIso2     String?
  countryName     String?
  ip              String?
  userAgent       String?
  raw             Json?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  brand  Brand                   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  events WebsiteAnalyticsEvent[]

  @@unique([brandId, sessionId])
  @@index([brandId, startedAt])
  @@index([brandId, sourceCategory, startedAt])
  @@index([brandId, landingPath, startedAt])
}

model WebsiteAnalyticsEvent {
  id               String                          @id @default(cuid())
  brandId          String
  websiteSessionId String
  eventId          String
  eventType        WebsiteAnalyticsEventType
  path             String?
  url              String?
  occurredAt       DateTime
  sourceCategory   WebsiteAnalyticsSourceCategory  @default(UNKNOWN)
  sourcePlatform   String?
  sourceMedium     WebsiteAnalyticsSourceMedium    @default(UNKNOWN)
  referer          String?
  referrerHost     String?
  countryIso2      String?
  countryName      String?
  ip               String?
  userAgent        String?
  conversionType   WebsiteAnalyticsConversionType?
  metricName       String?
  metricValue      Float?
  engagedSeconds   Int?
  raw              Json?
  createdAt        DateTime                        @default(now())

  brand   Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  session WebsiteSession @relation(fields: [websiteSessionId], references: [id], onDelete: Cascade)

  @@unique([brandId, eventId])
  @@index([brandId, occurredAt])
  @@index([brandId, websiteSessionId, occurredAt])
  @@index([brandId, eventType, occurredAt])
}
