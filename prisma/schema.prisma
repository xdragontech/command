// prisma/schema.prisma
// Requires XD_POSTGRES (Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("XD_POSTGRES")
}

enum BrandStatus {
  SETUP_PENDING
  ACTIVE
  DISABLED
}

enum BrandEnvironment {
  PRODUCTION
  PREVIEW
}

enum BrandHostKind {
  PUBLIC
  ADMIN
  APEX
  ALIAS
}

enum BrandEmailConfigStatus {
  ACTIVE
  INACTIVE
}

enum BrandEmailProvider {
  RESEND
}

enum BrandConsentNoticeStatus {
  DRAFT
  PUBLISHED
}

enum BackofficeRole {
  SUPERADMIN
  STAFF
}

enum BackofficeUserStatus {
  ACTIVE
  BLOCKED
}

enum BackofficeMfaMethod {
  AUTHENTICATOR_APP
}

enum ExternalUserStatus {
  ACTIVE
  BLOCKED
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(ACTIVE)
  role          UserRole   @default(USER)
  createdAt     DateTime   @default(now())
  lastLoginAt   DateTime?

  accounts      Account[]
  sessions      Session[]
  loginEvents   LoginEvent[]
  externalUsers ExternalUser[] @relation("LegacyUserToExternalUsers")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@index([identifier])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset flow (store HASHED token, not raw)
model PasswordResetToken {
  identifier String // user email (lowercased)
  token      String   @unique // SHA-256 hash of the raw token
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model LoginEvent {
  id          String   @id @default(cuid())
  userId      String
  ip          String
  countryIso2 String?
  countryName String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum PromptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ScheduleEventSeriesStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ScheduleRecurrencePattern {
  NONE
  WEEKLY
}

enum ScheduleWeekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum ScheduleEventOccurrenceStatus {
  SCHEDULED
  CANCELLED
}

enum ScheduleResourceType {
  STAGE
  FOOD_SPOT
  MARKET_SPOT
  OTHER
}

enum ScheduleParticipantType {
  ENTERTAINMENT
  FOOD_VENDOR
  MARKET_VENDOR
}

enum ScheduleParticipantStatus {
  ACTIVE
  INACTIVE
}

enum ScheduleAssignmentKind {
  TIMED_SLOT
  FULL_DAY
}

enum ScheduleAssignmentStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Brand {
  id        String      @id @default(cuid())
  brandKey  String      @unique
  name      String
  status    BrandStatus @default(SETUP_PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  hosts                           BrandHost[]
  emailConfig                     BrandEmailConfig?
  consentNotices                  BrandConsentNotice[]
  categories                      Category[]
  prompts                         Prompt[]
  articleCategories               ArticleCategory[]
  articles                        Article[]
  leads                           Lead[]
  leadEvents                      LeadEvent[]
  scheduleEventSerieses           ScheduleEventSeries[]
  scheduleEventOccurrences        ScheduleEventOccurrence[]
  scheduleResources               ScheduleResource[]
  scheduleParticipants            ScheduleParticipant[]
  scheduleAssignments             ScheduleAssignment[]
  staffAccesses                   BackofficeUserBrandAccess[]
  externalUsers                   ExternalUser[]
  externalAccounts                ExternalAccount[]
  externalLoginEvents             ExternalLoginEvent[]
  externalVerificationTokens      ExternalVerificationToken[]
  externalEmailVerificationTokens ExternalEmailVerificationToken[]
  externalPasswordResetTokens     ExternalPasswordResetToken[]
  websiteSessions                 WebsiteSession[]
  websiteAnalyticsEvents          WebsiteAnalyticsEvent[]
}

model BrandHost {
  id          String           @id @default(cuid())
  brandId     String
  host        String           @unique
  environment BrandEnvironment
  kind        BrandHostKind    @default(PUBLIC)
  isCanonical Boolean          @default(false)
  createdAt   DateTime         @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([environment, kind])
}

model BrandEmailConfig {
  id                String                 @id @default(cuid())
  brandId           String                 @unique
  status            BrandEmailConfigStatus @default(INACTIVE)
  provider          BrandEmailProvider     @default(RESEND)
  fromName          String?
  fromEmail         String?
  replyToEmail      String?
  supportEmail      String?
  providerSecretRef String?
  settings          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model BrandConsentNotice {
  id           String                  @id @default(cuid())
  brandId      String
  version      Int
  status       BrandConsentNoticeStatus
  title        String
  message      String
  acceptLabel  String
  declineLabel String
  publishedAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, version])
  @@index([brandId, status])
  @@index([brandId, publishedAt])
}

model ScheduleEventSeries {
  id                         String                    @id @default(cuid())
  brandId                    String
  name                       String
  slug                       String
  color                      String                    @default("#ef4444")
  description                String?
  timezone                   String
  status                     ScheduleEventSeriesStatus @default(DRAFT)
  recurrencePattern          ScheduleRecurrencePattern @default(NONE)
  recurrenceInterval         Int                       @default(1)
  recurrenceDays             ScheduleWeekday[]         @default([])
  seasonStartsOn             DateTime
  seasonEndsOn               DateTime
  occurrenceDayStartsAtMinutes Int                     @default(0)
  occurrenceDayEndsAtMinutes Int                       @default(1440)
  metadata                   Json?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  brand       Brand                    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  occurrences ScheduleEventOccurrence[]
  resources   ScheduleResource[]

  @@index([brandId])
  @@index([status])
  @@index([seasonStartsOn, seasonEndsOn])
  @@unique([brandId, slug])
}

model ScheduleEventOccurrence {
  id                       String                        @id @default(cuid())
  brandId                  String
  scheduleEventSeriesId    String
  name                     String?
  occursOn                 DateTime
  dayStartsAtMinutes       Int
  dayEndsAtMinutes         Int
  status                   ScheduleEventOccurrenceStatus @default(SCHEDULED)
  metadata                 Json?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  brand       Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  series      ScheduleEventSeries @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: Cascade)
  assignments ScheduleAssignment[]

  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([occursOn])
  @@index([brandId, occursOn])
  @@unique([scheduleEventSeriesId, occursOn])
}

model ScheduleResource {
  id                    String               @id @default(cuid())
  brandId               String
  scheduleEventSeriesId String?
  name                  String
  slug                  String
  type                  ScheduleResourceType
  description           String?
  sortOrder             Int                  @default(0)
  isActive              Boolean              @default(true)
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  brand       Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  series      ScheduleEventSeries? @relation(fields: [scheduleEventSeriesId], references: [id], onDelete: SetNull)
  assignments ScheduleAssignment[]

  @@index([brandId])
  @@index([scheduleEventSeriesId])
  @@index([type, isActive])
  @@unique([brandId, slug])
  @@unique([brandId, name])
}

model ScheduleParticipant {
  id          String                    @id @default(cuid())
  brandId     String
  displayName String
  slug        String
  type        ScheduleParticipantType
  status      ScheduleParticipantStatus @default(ACTIVE)
  summary     String?
  metadata    Json?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  brand       Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  assignments ScheduleAssignment[]

  @@index([brandId])
  @@index([type, status])
  @@index([displayName])
  @@unique([brandId, slug])
}

model ScheduleAssignment {
  id                        String                   @id @default(cuid())
  brandId                   String
  scheduleEventOccurrenceId String
  scheduleResourceId        String
  scheduleParticipantId     String
  kind                      ScheduleAssignmentKind
  status                    ScheduleAssignmentStatus @default(DRAFT)
  startsAtMinutes           Int
  endsAtMinutes             Int
  publicTitle               String?
  publicSubtitle            String?
  publicDescription         String?
  publicLocationLabel       String?
  publicUrl                 String?
  internalNotes             String?
  metadata                  Json?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  brand       Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  occurrence  ScheduleEventOccurrence @relation(fields: [scheduleEventOccurrenceId], references: [id], onDelete: Cascade)
  resource    ScheduleResource        @relation(fields: [scheduleResourceId], references: [id], onDelete: Cascade)
  participant ScheduleParticipant     @relation(fields: [scheduleParticipantId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([scheduleEventOccurrenceId])
  @@index([brandId, scheduleEventOccurrenceId])
  @@index([scheduleResourceId])
  @@index([scheduleParticipantId])
  @@index([status])
  @@unique([scheduleEventOccurrenceId, scheduleResourceId, scheduleParticipantId, startsAtMinutes, endsAtMinutes])
}

model InstallProfile {
  id               String   @id @default("install")
  displayName      String?
  setupCompletedAt DateTime?
  primaryBrandId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([primaryBrandId])
}

model BackofficeUser {
  id                          String               @id @default(cuid())
  username                    String               @unique
  email                       String?              @unique
  passwordHash                String
  role                        BackofficeRole       @default(STAFF)
  status                      BackofficeUserStatus @default(ACTIVE)
  mfaMethod                   BackofficeMfaMethod?
  mfaEnabledAt                DateTime?
  mfaSecretEncrypted          String?
  mfaRecoveryCodesEncrypted   String?
  mfaRecoveryCodesGeneratedAt DateTime?
  lastSelectedBrandKey        String?
  uiPreferences               Json?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  lastLoginAt                 DateTime?

  brandAccesses BackofficeUserBrandAccess[]
  accounts      BackofficeAccount[]
  sessions      BackofficeSession[]
  loginEvents   BackofficeLoginEvent[]

  @@index([email])
}

model BackofficeLoginEvent {
  id               String   @id @default(cuid())
  backofficeUserId String
  ip               String
  countryIso2      String?
  countryName      String?
  userAgent        String?
  createdAt        DateTime @default(now())

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@index([backofficeUserId])
  @@index([createdAt])
}

model BackofficeUserBrandAccess {
  userId    String
  brandId   String
  createdAt DateTime @default(now())

  user  BackofficeUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([userId, brandId])
  @@index([brandId])
}

model BackofficeAccount {
  id                String  @id @default(cuid())
  backofficeUserId  String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([backofficeUserId])
}

model BackofficeSession {
  id               String   @id @default(cuid())
  sessionToken     String   @unique
  backofficeUserId String
  expires          DateTime

  user BackofficeUser @relation(fields: [backofficeUserId], references: [id], onDelete: Cascade)

  @@index([backofficeUserId])
}

model BackofficeVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

model BackofficePasswordResetToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model ExternalUser {
  id            String             @id @default(cuid())
  brandId       String
  legacyUserId  String?
  email         String?
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  status        ExternalUserStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lastLoginAt   DateTime?

  brand       Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  legacyUser  User?                @relation("LegacyUserToExternalUsers", fields: [legacyUserId], references: [id], onDelete: SetNull)
  accounts    ExternalAccount[]
  sessions    ExternalSession[]
  loginEvents ExternalLoginEvent[]

  @@unique([brandId, email])
  @@index([brandId])
  @@index([email])
  @@index([legacyUserId])
}

model ExternalAccount {
  id                String  @id @default(cuid())
  externalUserId    String
  brandId           String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user  ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  brand Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, provider, providerAccountId])
  @@index([externalUserId])
  @@index([brandId])
}

model ExternalSession {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  externalUserId String
  expires        DateTime

  user ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)

  @@index([externalUserId])
}

model ExternalLoginEvent {
  id             String   @id @default(cuid())
  externalUserId String
  brandId        String
  ip             String
  countryIso2    String?
  countryName    String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user  ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  brand Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([externalUserId])
  @@index([brandId])
  @@index([createdAt])
}

model ExternalVerificationToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, identifier, token])
  @@index([brandId, identifier])
}

model ExternalEmailVerificationToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model ExternalPasswordResetToken {
  brandId    String
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, identifier])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  brandId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  brand   Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  prompts Prompt[]

  @@index([brandId])
  @@unique([brandId, name])
  @@unique([brandId, slug])
}

model Prompt {
  id          String       @id @default(cuid())
  title       String
  description String?
  content     String
  status      PromptStatus @default(DRAFT)

  // Ordering + tags
  sortOrder Int      @default(0)
  tags      String[] @default([])

  brandId    String?
  categoryId String?
  brand      Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([categoryId])
  @@index([title])
}

// --- Articles (separate from Prompt Library) ---

model ArticleCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String
  brandId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  articles Article[]

  @@index([brandId])
  @@unique([brandId, name])
  @@unique([brandId, slug])
}

model Article {
  id      String       @id @default(cuid())
  title   String
  slug    String
  summary String
  content String
  status  PromptStatus @default(DRAFT)

  brandId    String?
  categoryId String?
  brand      Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category   ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Optional tags (Postgres text[])
  tags String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@unique([brandId, slug])
  @@index([status])
  @@index([categoryId])
  @@index([title])
}

// --- Leads (durable lead records for cross-referencing / analytics) ---

enum LeadSource {
  CONTACT
  CHAT
}

enum WebsiteAnalyticsSourceCategory {
  DIRECT
  SEARCH
  SOCIAL
  REFERRAL
  EMAIL
  PAID
  AI_REFERRAL
  UNKNOWN
}

enum WebsiteAnalyticsSourceMedium {
  DIRECT
  ORGANIC
  SOCIAL
  REFERRAL
  EMAIL
  PAID
  AI_REFERRAL
  UNKNOWN
}

enum WebsiteAnalyticsEventType {
  SESSION_START
  PAGE_VIEW
  ENGAGEMENT_PING
  SESSION_END
  CONVERSION
  WEB_VITAL
  PERFORMANCE_METRIC
}

enum WebsiteAnalyticsConversionType {
  CONTACT_SUBMIT
  CHAT_LEAD_SUBMIT
  CLIENT_LOGIN_SUCCESS
  CLIENT_SIGNUP_CREATED
  CLIENT_SIGNUP_VERIFIED
}

model Lead {
  id        String     @id @default(cuid())
  brandId   String?
  source    LeadSource
  name      String?
  email     String?
  ip        String?
  raw       Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  brand  Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)
  events LeadEvent[]

  @@index([brandId])
  @@index([source])
  @@index([createdAt])
  @@index([email])
}

// --- Lead events (append-only timeline; source of truth for Leads + Analytics) ---

model LeadEvent {
  id             String     @id @default(cuid())
  brandId        String?
  source         LeadSource
  // Optional: link to a durable Lead summary row when available (CONTACT always, CHAT optionally)
  leadId         String?
  conversationId String?
  ip             String?
  countryIso2    String?
  countryName    String?
  userAgent      String?
  referer        String?
  raw            Json?
  createdAt      DateTime   @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  lead  Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([source])
  @@index([createdAt])
  @@index([leadId])
  @@index([conversationId])
}

model WebsiteSession {
  id              String                         @id @default(cuid())
  brandId         String
  sessionId       String
  startedAt       DateTime
  lastSeenAt      DateTime
  endedAt         DateTime?
  landingUrl      String?
  landingPath     String?
  lastPath        String?
  pageViewCount   Int                            @default(0)
  engagedSeconds  Int                            @default(0)
  engaged         Boolean                        @default(false)
  bounced         Boolean                        @default(false)
  converted       Boolean                        @default(false)
  conversionCount Int                            @default(0)
  sourceCategory  WebsiteAnalyticsSourceCategory @default(UNKNOWN)
  sourcePlatform  String?
  sourceMedium    WebsiteAnalyticsSourceMedium   @default(UNKNOWN)
  referrerHost    String?
  referer         String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  fbclid          String?
  msclkid         String?
  ttclid          String?
  countryIso2     String?
  countryName     String?
  ip              String?
  userAgent       String?
  raw             Json?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  brand  Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  events WebsiteAnalyticsEvent[]

  @@unique([brandId, sessionId])
  @@index([brandId, startedAt])
  @@index([brandId, sourceCategory, startedAt])
  @@index([brandId, landingPath, startedAt])
}

model WebsiteAnalyticsEvent {
  id               String                         @id @default(cuid())
  brandId          String
  websiteSessionId String
  eventId          String
  eventType        WebsiteAnalyticsEventType
  path             String?
  url              String?
  occurredAt       DateTime
  sourceCategory   WebsiteAnalyticsSourceCategory @default(UNKNOWN)
  sourcePlatform   String?
  sourceMedium     WebsiteAnalyticsSourceMedium   @default(UNKNOWN)
  referer          String?
  referrerHost     String?
  countryIso2      String?
  countryName      String?
  ip               String?
  userAgent        String?
  conversionType   WebsiteAnalyticsConversionType?
  metricName       String?
  metricValue      Float?
  engagedSeconds   Int?
  raw              Json?
  createdAt        DateTime                       @default(now())

  brand   Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  session WebsiteSession @relation(fields: [websiteSessionId], references: [id], onDelete: Cascade)

  @@unique([brandId, eventId])
  @@index([brandId, occurredAt])
  @@index([brandId, websiteSessionId, occurredAt])
  @@index([brandId, eventType, occurredAt])
}
