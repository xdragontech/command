# Command public-api local/dev example

# Required: install database
XD_POSTGRES=postgresql://user:password@host/database?sslmode=require

# Required: integration clients allowed to call this install
# One entry per public-site BFF. Keep keys unique per install.
COMMAND_PUBLIC_INTEGRATIONS_JSON=[{"name":"xdragon-staging-site","key":"replace-me","brandKey":"xdragon","publicOrigin":"https://staging.xdragon.tech"}]

# Required when a brand's BrandEmailConfig.providerSecretRef resolves to this env key.
# The default current setup uses RESEND_API_KEY.
RESEND_API_KEY=re_replace_me
