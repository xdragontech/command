{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@command/core-config": [
        "packages/core-config/src/index.ts"
      ],
      "@command/core-db": [
        "packages/core-db/src/index.ts"
      ],
      "@command/core-brand-runtime": [
        "packages/core-brand-runtime/src/index.ts"
      ],
      "@command/core-email": [
        "packages/core-email/src/index.ts"
      ]
    }
  }
}
