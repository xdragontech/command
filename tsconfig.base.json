{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "paths": {
      "@command/core-config": [
        "packages/core-config/src/index.ts"
      ],
      "@command/core-db": [
        "packages/core-db/src/index.ts"
      ],
      "@command/core-brand-runtime": [
        "packages/core-brand-runtime/src/index.ts"
      ],
      "@command/core-auth-backoffice": [
        "packages/core-auth-backoffice/src/index.ts"
      ],
      "@command/core-auth-external": [
        "packages/core-auth-external/src/index.ts"
      ],
      "@command/core-email": [
        "packages/core-email/src/index.ts"
      ],
      "@command/core-leads": [
        "packages/core-leads/src/index.ts"
      ],
      "@command/core-scheduling": [
        "packages/core-scheduling/src/index.ts"
      ],
      "@command/core-content": [
        "packages/core-content/src/index.ts"
      ],
      "@command/core-website-analytics": [
        "packages/core-website-analytics/src/index.ts"
      ]
    }
  }
}
